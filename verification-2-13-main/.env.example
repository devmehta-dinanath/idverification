# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# AWS Configuration (for Rekognition, Textract, S3)
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
# AWS Credentials should be set as AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY in Vercel/Netlify env vars directly, not typically in .env for Next.js unless using custom client config.
# However, the AWS SDK v3 automatically picks up AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY from the environment.

